  "scripts": {
    "test": "node --test",
    "check": "node --test && node --check ./affinity_package.mjs && node --check ./affinity_sdk.mjs && node --check ./affinity_direct_client.mjs && node --check ./affinity_mcp_proxy.mjs"
  },
  "keywords": [
    "affinity",
    "mcp",
    "proxy",
    "stdio",
    "model-context-protocol"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5"
  }
}
